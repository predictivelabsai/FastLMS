# FastLMS environment variables
# Copy to .env and fill in values

# PostgreSQL database URL (required)
DB_URL=postgresql://user:password@localhost:5432/your_database

# Session secret (change in production)
SESSION_SECRET=fastlms-change-me-in-production

# LLM provider for AI Tutor chat (xai | openai | anthropic)
MODEL_PROVIDER=xai
DEFAULT_MODEL=grok-4-1-fast-reasoning

# API keys (only the one matching MODEL_PROVIDER is needed)
XAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
